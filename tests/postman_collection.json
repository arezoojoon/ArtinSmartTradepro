{
    "info": {
        "name": "Artin Smart Trade — Full API Testing",
        "description": "Complete API test collection for auth, billing, trade intelligence, AI modules, and admin. Generated by system audit.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000/api/v1"
        },
        {
            "key": "token",
            "value": ""
        },
        {
            "key": "refresh_token",
            "value": ""
        },
        {
            "key": "tenant_id",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/register",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"email\":\"test@postman.com\",\"password\":\"secure123\",\"full_name\":\"Test User\",\"company_name\":\"Postman Corp\"}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "var data = pm.response.json();",
                                    "pm.collectionVariables.set('tenant_id', data.tenant_id);"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/login",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/x-www-form-urlencoded"
                            }
                        ],
                        "body": {
                            "mode": "urlencoded",
                            "urlencoded": [
                                {
                                    "key": "username",
                                    "value": "test@postman.com"
                                },
                                {
                                    "key": "password",
                                    "value": "secure123"
                                }
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "var data = pm.response.json();",
                                    "pm.test('Has access_token', () => pm.expect(data.access_token).to.exist);",
                                    "pm.test('Has refresh_token', () => pm.expect(data.refresh_token).to.exist);",
                                    "pm.collectionVariables.set('token', data.access_token);",
                                    "pm.collectionVariables.set('refresh_token', data.refresh_token);"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Refresh Token",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/refresh",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"refresh_token\":\"{{refresh_token}}\"}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "var data = pm.response.json();",
                                    "pm.collectionVariables.set('token', data.access_token);"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Forgot Password — Token Leak Check",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/forgot-password",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"email\":\"test@postman.com\"}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "var data = pm.response.json();",
                                    "pm.test('SECURITY: reset_token MUST NOT be in response', () => pm.expect(data.reset_token).to.be.undefined);"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/logout",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
        {
            "name": "Plan Gating",
            "item": [
                {
                    "name": "Professional BLOCKS: Trade Intelligence",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/trade/analyze/seasonal",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "X-Tenant-ID",
                                "value": "{{tenant_id}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"product\":\"cocoa\",\"region\":\"europe\"}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Professional blocked from trade: 403', () => pm.response.to.have.status(403));"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "No Auth: 401",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/trade/analyze/seasonal",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"product\":\"cocoa\",\"region\":\"europe\"}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('No auth returns 401', () => pm.response.to.have.status(401));"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
        {
            "name": "Brain Intelligence",
            "item": [
                {
                    "name": "Brain Decide (Enterprise)",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/brain/decide",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "X-Tenant-ID",
                                "value": "{{tenant_id}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"product\":\"cocoa\",\"origin_country\":\"Ghana\",\"destination_country\":\"Germany\",\"quantity_kg\":1000,\"budget_usd\":50000}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200 or 403', () => [200,403].includes(pm.response.code));"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Brain Arbitrage (Enterprise)",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/brain/arbitrage",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "X-Tenant-ID",
                                "value": "{{tenant_id}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"product\":\"cocoa\",\"origin_country\":\"Ghana\",\"destination_country\":\"Germany\"}"
                        }
                    }
                }
            ]
        },
        {
            "name": "Billing",
            "item": [
                {
                    "name": "Wallet Balance (missing endpoint test)",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/billing/wallet",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "X-Tenant-ID",
                                "value": "{{tenant_id}}"
                            }
                        ]
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('BUG: /billing/wallet returns 404 (endpoint missing)', () => pm.response.to.have.status(404));"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
        {
            "name": "Health Check",
            "item": [
                {
                    "name": "Health",
                    "request": {
                        "method": "GET",
                        "url": "http://localhost:8000/health"
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Health OK', () => pm.response.to.have.status(200));",
                                    "pm.test('Version is 2.0.0', () => pm.expect(pm.response.json().version).to.equal('2.0.0'));"
                                ]
                            }
                        }
                    ]
                }
            ]
        }
    ]
}