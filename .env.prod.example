# =============================================================================
# Artin Smart Trade - Production Environment Configuration
# =============================================================================

# Database Configuration
POSTGRES_PASSWORD=your_very_secure_database_password_here
DATABASE_URL=postgresql://postgres:your_very_secure_database_password_here@db:5432/artin_smart_trade

# Application Security
SECRET_KEY=your_very_secure_secret_key_minimum_32_characters
JWT_SECRET_KEY=your_very_secure_jwt_secret_key_minimum_32_characters

# Payment Processing (Stripe)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# External API Keys
COMTRADE_API_KEY=your_un_comtrade_api_key_here
FREIGHT_API_KEY=your_freight_rates_api_key_here
FX_API_KEY=your_foreign_exchange_api_key_here
GEMINI_API_KEY=your_google_gemini_vision_api_key_here
OPENAI_API_KEY=your_openai_api_key_for_whisper_here

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@domain.com
SMTP_PASSWORD=your_app_specific_password_here

# Redis Configuration
REDIS_URL=redis://redis:6379

# Application Settings
DEBUG=false
ENVIRONMENT=production
NODE_ENV=production

# Frontend Configuration
NEXT_PUBLIC_API_URL=https://api.artin-smart-trade.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here
NEXT_PUBLIC_APP_NAME=Artin Smart Trade
NEXT_PUBLIC_APP_VERSION=2.0.0

# Monitoring Configuration
GRAFANA_PASSWORD=your_secure_grafana_password_here

# Security Settings
CORS_ORIGINS=["https://artin-smart-trade.com"]
ALLOWED_HOSTS=["artin-smart-trade.com", "api.artin-smart-trade.com"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# File Upload Settings
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=["pdf","doc","docx","jpg","jpeg","png","gif"]

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# SSL/TLS Configuration
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Performance Settings
WORKER_PROCESSES=4
WORKER_CONNECTIONS=1024
KEEPALIVE_TIMEOUT=65

# Health Check Settings
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# Monitoring and Alerting
PROMETHEUS_RETENTION=30d
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_USER=alerts@artin-smart-trade.com
ALERT_EMAIL_PASSWORD=your_alert_email_password

# Session Configuration
SESSION_TIMEOUT_MINUTES=15
MAX_CONCURRENT_SESSIONS=3

# Multi-tenancy Settings
DEFAULT_TENANT_PLAN=professional
MAX_TENANT_USERS=100
MAX_TENANT_DEALS=10000

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_MULTI_LANGUAGE=false
ENABLE_API_V2=false

# Compliance Settings
DATA_RETENTION_DAYS=2555  # 7 years
AUDIT_LOG_RETENTION_DAYS=365
COMPLIANCE_REPORTING_ENABLED=true

# Integration Settings
WEBHOOK_TIMEOUT=30
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_SECRET=your_webhook_secret_for_signing

# Cache Settings
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# Search Settings
SEARCH_RESULTS_LIMIT=50
SEARCH_FUZZY_THRESHOLD=0.8

# Notification Settings
NOTIFICATION_BATCH_SIZE=100
NOTIFICATION_RETRY_ATTEMPTS=3

# Analytics Settings
ANALYTICS_RETENTION_DAYS=365
METRICS_COLLECTION_INTERVAL=60

# Development Overrides (should be false in production)
ENABLE_DEBUG_ENDPOINTS=false
ENABLE_PROFILING=false
ENABLE_SWAGGER_UI=false
