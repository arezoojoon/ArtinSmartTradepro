# ─── Artin Smart Trade — Production Environment Variables ───
# Copy this file to .env and fill in all values before deploying.

# ─── Security (REQUIRED) ──────────────────────────────────
SECRET_KEY=GENERATE_A_64_CHAR_RANDOM_STRING_HERE
FIRST_SUPERUSER=admin@artin.com
FIRST_SUPERUSER_PASSWORD=CHANGE_THIS_PASSWORD

# ─── Environment ──────────────────────────────────────────
ENVIRONMENT=production

# ─── Database ─────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_DB_PASSWORD
POSTGRES_DB=artin_trade
POSTGRES_SERVER=db
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Gemini AI Keys ──────────────────────────────────────
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# ─── WhatsApp ────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=artin_webhook_verify_2026

# ─── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Frontend ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://trade.artinsmartagent.com/api/v1
FRONTEND_URL=https://trade.artinsmartagent.com
