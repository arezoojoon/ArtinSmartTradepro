# ─── Core App ─────────────────────────────────────────────
ENVIRONMENT=production
APP_URL=https://trade.artinsmartagent.com
FRONTEND_URL=https://trade.artinsmartagent.com
NEXT_PUBLIC_API_URL=https://trade.artinsmartagent.com/api/v1
SECRET_KEY=GENERATE_A_64_CHAR_RANDOM_STRING
FIRST_SUPERUSER=admin@artin.com
# IMPORTANT: If your password contains '$', escape it as '$$' for Docker Compose (e.g., p@$$w0rd)
FIRST_SUPERUSER_PASSWORD=CHANGE_ME_STRONG
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Database ─────────────────────────────────────────────
POSTGRES_DB=artin_trade
POSTGRES_USER=artin
POSTGRES_PASSWORD=CHANGE_ME_STRONG

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── MinIO (S3 compatible) ───────────────────────────────
MINIO_ROOT_USER=artinminio
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG
S3_ENDPOINT=http://minio:9000
S3_BUCKET=artin-docs
S3_ACCESS_KEY=artinminio
S3_SECRET_KEY=CHANGE_ME_STRONG

# ─── Gemini AI Keys ──────────────────────────────────────
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# ─── WhatsApp / WAHA ─────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WAHA_API_URL=http://waha:3000
WAHA_API_KEY=
WAHA_SESSION=default

# ─── Feature Flags ───────────────────────────────────────
ENABLE_SCRAPING=true
ENABLE_OUTREACH=true
