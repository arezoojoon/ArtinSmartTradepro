# App
ENV=production
APP_URL=https://yourdomain.com
JWT_SECRET=CHANGE_ME_LONG_RANDOM
LOG_LEVEL=INFO

# Database
POSTGRES_DB=artin_trade
POSTGRES_USER=artin
POSTGRES_PASSWORD=CHANGE_ME_STRONG
DATABASE_URL=postgresql+asyncpg://artin:CHANGE_ME_STRONG@db:5432/artin_trade

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3 compatible)
MINIO_ROOT_USER=artinminio
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG
S3_ENDPOINT=http://minio:9000
S3_BUCKET=artin-docs
S3_ACCESS_KEY=artinminio
S3_SECRET_KEY=CHANGE_ME_STRONG

# AI (Gemini)
GEMINI_API_KEY=YOUR_KEY

# Feature flags
ENABLE_SCRAPING=true
ENABLE_OUTREACH=true

# Tenancy (if you use DB tenant session var)
DB_TENANT_GUC_KEY=app.tenant_id
